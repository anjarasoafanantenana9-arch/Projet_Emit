@* Modèle : (Titre, SousTitre) *@
@model (string Titre, string SousTitre)

<div class="top-header">
    <div>
        <h4 class="fw-bold mb-0 text-dark">@Model.Titre</h4>
        <p class="text-muted small mb-0">@Model.SousTitre</p>
    </div>
    <div class="d-flex align-items-center bg-white py-1 px-3 rounded-pill border shadow-sm">
        <span class="text-muted me-2 small">Enseignant :</span>
        <span class="fw-bold text-dark me-2">@ViewBag.NomEnseignant</span>
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;">
            @(((string)ViewBag.NomEnseignant ?? "P").Trim().FirstOrDefault().ToString().ToUpper())
        </div>
    </div>
</div>
