@model EMIT.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Inscription";
}

<h1>Créer un compte</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Register" method="post" style="max-width: 480px;">
    <div class="form-group mb-3">
        <label asp-for="Nom" class="control-label"></label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Prenom" class="control-label"></label>
        <input asp-for="Prenom" class="form-control" />
        <span asp-validation-for="Prenom" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Email" class="control-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MotDePasse" class="control-label"></label>
        <input asp-for="MotDePasse" class="form-control" />
        <span asp-validation-for="MotDePasse" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ConfirmationMotDePasse" class="control-label"></label>
        <input asp-for="ConfirmationMotDePasse" class="form-control" />
        <span asp-validation-for="ConfirmationMotDePasse" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Role" class="control-label"></label>
        <select asp-for="Role" id="Role" class="form-control">
            <option value="@((int)EMIT.Models.RoleUtilisateur.Etudiant)">Étudiant</option>
            <option value="@((int)EMIT.Models.RoleUtilisateur.Enseignant)">Enseignant</option>
        </select>
        <small class="form-text text-muted">Les comptes Administrateur sont créés séparément par un administrateur existant.</small>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>

    <div class="form-group mb-3" id="groupeClasse" style="display:none;">
        <label asp-for="IdClasse" class="control-label">Classe</label>
        <select asp-for="IdClasse" class="form-control" asp-items="ViewBag.IdClasse">
            <option value="">-- Sélectionner --</option>
        </select>
        <span asp-validation-for="IdClasse" class="text-danger"></span>
    </div>

    <div class="form-group mb-3" id="groupePlafond" style="display:none;">
        <label asp-for="PlafondHeuresJournalieres" class="control-label"></label>
        <input asp-for="PlafondHeuresJournalieres" class="form-control" value="6" />
        <span asp-validation-for="PlafondHeuresJournalieres" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">S'inscrire</button>
    <a asp-action="Login" class="btn btn-link">J'ai déjà un compte</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function ajusterChampsSelonRole() {
            var role = document.getElementById('Role').value; // "0"=Administrateur,"1"=Enseignant,"2"=Etudiant
            document.getElementById('groupeClasse').style.display = (role === '2') ? 'block' : 'none';
            document.getElementById('groupePlafond').style.display = (role === '1') ? 'block' : 'none';
        }
        document.getElementById('Role').addEventListener('change', ajusterChampsSelonRole);
        ajusterChampsSelonRole();
    </script>
}
