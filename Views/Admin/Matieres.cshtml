@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gestion des Matières";
}

<link rel="stylesheet" href="~/css/admin-matieres.css" />

<div class="content-body">
    <div class="row g-4"> <div class="col-lg-4">
            <div class="card-custom animate-fade-in">
                <div class="card-title-custom">
                    Ajouter une matière
                </div>

                <form id="formMatiere">
                    <input type="hidden" id="idMatiere">

                    <div class="mb-4">
                        <label class="form-label">Nom de la matière</label>
                        <input type="text" id="nomMatiere" class="form-control" placeholder="Ex: Mathématiques" required>
                    </div>

                    <button class="btn btn-navy w-100">
                        Enregistrer
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card-custom animate-fade-in">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="card-title-custom mb-0">
                        Liste des matières
                    </div>
                    <button class="btn btn-outline-navy btn-sm" onclick="chargerMatieres()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-arrow-clockwise me-1" viewBox="0 0 16 16">
                          <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/>
                          <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/>
                        </svg>
                        Actualiser
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th style="width: 15%">ID</th>
                                <th class="text-start">Matière</th>
                                <th style="width: 25%">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="tableMatieres">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts{
    <script src="~/js/admin-matieres.js"></script>
}