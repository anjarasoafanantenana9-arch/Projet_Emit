@{
    var page = ViewData["ActivePage"] as string ?? "";
    string ActiveClass(string key) => page == key ? "sidebar-link active" : "sidebar-link";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMIT - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --sidebar-width: 200px;
            --navy-dark: #0a1128;
            --navy-muted: #475569;
            --emit-blue: #0d6efd;
            --emit-blue-light: #e0f2fe;
            --bg-main: #f8fafc;
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            font-size: 0.82rem;
            min-height: 100vh;
            overflow-x: hidden;
            color: #334155;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: var(--sidebar-width);
            background-color: #ffffff;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 20px 0;
            z-index: 1000;
            border-right: 1px solid var(--border-color);
        }

        .sidebar-brand {
            padding: 0 16px 20px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .sidebar-brand .logo-wrapper {
                background: #ffffff;
                padding: 6px 12px;
                border-radius: 8px;
                display: inline-block;
                border: 1px solid var(--border-color);
                width: 100%;
                text-align: center;
                font-weight: 800;
                color: var(--emit-blue);
                letter-spacing: 0.5px;
            }

        .sidebar-menu {
            list-style: none;
            padding: 0 12px;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .menu-label {
            color: #94a3b8;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-weight: 700;
            padding: 15px 12px 4px 12px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--navy-muted);
            text-decoration: none;
            padding: 9px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            transition: all 0.2s ease;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

            .sidebar-link i { font-size: 0.95rem; color: #64748b; transition: color 0.2s ease; }
            .sidebar-link:hover { color: var(--navy-dark); background-color: #f1f5f9; }
            .sidebar-link:hover i { color: var(--navy-dark); }
            .sidebar-link.active { background-color: var(--emit-blue-light); color: var(--emit-blue); font-weight: 600; }
            .sidebar-link.active i { color: var(--emit-blue); }

        /* --- MAIN --- */
        .main-content { margin-left: var(--sidebar-width); min-height: 100vh; display: flex; flex-direction: column; }

        .topbar {
            background-color: #ffffff;
            height: 55px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            border-bottom: 1px solid var(--border-color);
        }

        .topbar-title h2 { font-size: 0.98rem; font-weight: 700; color: var(--navy-dark); margin: 0; }
        .topbar-title span { font-size: 0.72rem; color: #94a3b8; }

        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .user-profile { display: flex; align-items: center; gap: 8px; }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background-color: var(--emit-blue-light); display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 0.75rem; color: var(--emit-blue); border: 1px solid var(--border-color);
        }

        .content-body { padding: 20px; flex: 1; }

        .card-custom { background: #ffffff; border-radius: 10px; border: 1px solid var(--border-color); padding: 18px; }
        .card-title-custom { font-size: 0.9rem; font-weight: 700; color: var(--navy-dark); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }

        .form-label { font-size: 0.75rem; font-weight: 600; color: #475569; margin-bottom: 4px; }
        .form-select, .form-control {
            border: 1px solid #cbd5e1; padding: 6px 10px; border-radius: 6px; font-size: 0.8rem; color: var(--navy-dark);
        }
            .form-select:focus, .form-control:focus { border-color: var(--emit-blue); box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.12); }

        /* --- TIMETABLE --- */
        .table-timetable { border-collapse: separate; border-spacing: 0; border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; }
            .table-timetable th {
                background-color: #f8fafc; color: var(--navy-dark); font-weight: 700; text-transform: uppercase;
                font-size: 0.72rem; letter-spacing: 0.5px; padding: 10px; border-bottom: 1px solid var(--border-color); text-align: center;
            }
            .table-timetable td {
                height: 120px; vertical-align: top; width: 20%; background-color: #ffffff;
                border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); padding: 8px;
            }
            .table-timetable td:last-child { border-right: none; }

        .course-slot {
            background-color: var(--emit-blue-light);
            border-left: 3px solid var(--emit-blue);
            padding: 6px 8px;
            border-radius: 6px;
            margin-bottom: 6px;
            font-size: 0.75rem;
            line-height: 1.35;
            color: var(--navy-dark);
        }

        .course-time {
            font-weight: 700;
            color: var(--emit-blue);
            font-size: 0.72rem;
            display: flex;
            align-items: center;
            gap: 3px;
            margin-bottom: 3px;
        }

        .course-matiere { font-weight: 600; }
        .course-prof { color: #475569; font-size: 0.72rem; }

        .badge-salle {
            display: inline-block;
            background-color: #ffffff;
            color: var(--navy-dark);
            padding: 2px 6px;
            font-size: 0.65rem;
            font-weight: 600;
            border-radius: 4px;
            margin-top: 4px;
            border: 1px solid #cbd5e1;
        }

        .empty-cell { color: #cbd5e1; font-size: 0.7rem; text-align: center; padding-top: 30px; }

        /* --- INFO SALLE (mini carte) --- */
        .salle-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 8px;
        }
            .salle-item:last-child { margin-bottom: 0; }

        .salle-icon {
            width: 32px; height: 32px; border-radius: 8px; background-color: var(--emit-blue-light);
            color: var(--emit-blue); display: flex; align-items: center; justify-content: center; font-size: 1rem;
        }

        .spinner-wrap { display: flex; align-items: center; justify-content: center; padding: 40px 0; color: #94a3b8; font-size: 0.78rem; gap: 8px; }

        .stat-card { display: flex; align-items: center; gap: 14px; }
        .stat-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--emit-blue-light); color: var(--emit-blue); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .stat-value { font-size: 1.3rem; font-weight: 700; color: var(--navy-dark); }
        .stat-label { font-size: 0.72rem; color: #94a3b8; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-brand">
            <div class="logo-wrapper">
                <img src="/images/emit-logo.png" alt="Logo EMIT" style="max-width: 100%;">
            </div>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/Etudiant" class="@ActiveClass("Dashboard")"><i class="bi bi-speedometer2"></i> Tableau de bord</a></li>

            <div class="menu-label">Ma Scolarité</div>
            <li><a href="/Etudiant/EmploiDuTemps" class="@ActiveClass("EmploiDuTemps")"><i class="bi bi-calendar3"></i> Emploi du Temps</a></li>
            <li><a href="/Etudiant/Salles" class="@ActiveClass("Salles")"><i class="bi bi-door-open"></i> Mes Salles</a></li>

            <div class="menu-label">Compte</div>
            <li><a href="/Etudiant/Profil" class="@ActiveClass("Profil")"><i class="bi bi-person"></i> Mon Profil</a></li>
        </ul>

        <form asp-controller="Account" asp-action="Logout" method="post" style="padding: 0 12px; margin-top: auto;">
            <button type="submit" class="sidebar-link border-0 bg-transparent w-100 text-start" style="cursor: pointer;">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </button>
        </form>
    </div>

    <div class="main-content">

        <div class="topbar">
            <div class="topbar-title">
                <h2>@ViewData["Title"]</h2>
                <span>@ViewData["Subtitle"]</span>
            </div>
            <div class="topbar-right">
                <div class="user-profile">
                    <span class="text-muted fw-medium" style="font-size: 0.75rem;">@User.Identity?.Name</span>
                    <div class="user-avatar">@(User.Identity?.Name?.Substring(0, 1) ?? "E")</div>
                </div>
            </div>
        </div>

        <div class="content-body">
            @if (TempData["Succes"] != null)
            {
                <div class="alert alert-success py-2" style="font-size: 0.8rem;">@TempData["Succes"]</div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
