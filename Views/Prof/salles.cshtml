@model IEnumerable<EMIT.ViewModels.SalleDisponibiliteViewModel>

@{
    ViewData["Title"] = "Salles - Espace Enseignant";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/prof.css" rel="stylesheet">
</head>
<body>

    @await Html.PartialAsync("_ProfSidebar", "Salles")

    <div class="main-content">

        @await Html.PartialAsync("_ProfHeader", ("Disponibilité des Salles", "Espace Enseignant > Salles de cours"))

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold text-dark mb-0">Salles de l'EMIT</h5>
            <a asp-action="Salles" class="btn btn-outline-primary btn-sm rounded-3">
                <i class="bi bi-arrow-clockwise me-1"></i> Actualiser l'état
            </a>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @if (!Model.Any())
            {
                <div class="col-12">
                    <div class="custom-card text-center text-muted">
                        Aucune salle enregistrée pour le moment.
                    </div>
                </div>
            }

            @foreach (var salle in Model)
            {
                <div class="col">
                    <div class="card h-100 custom-card">
                        <div class="card-body p-0">
                            <div class="d-flex align-items-center mb-3">
                                <div class="room-icon-box bg-primary bg-opacity-10 text-primary p-3 me-3">
                                    <i class="bi bi-building"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0 text-dark">@salle.NomSalle</h5>
                                    <span class="text-muted small">Capacité : @salle.Capacite places</span>
                                </div>
                                @if (salle.EstLibre)
                                {
                                    <span class="badge bg-success-subtle text-success ms-auto px-2 py-1 rounded-pill">
                                        <i class="bi bi-check-circle-fill me-1"></i> Libre
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger ms-auto px-2 py-1 rounded-pill">
                                        <i class="bi bi-dash-circle-fill me-1"></i> Occupée
                                    </span>
                                }
                            </div>
                            @if (!salle.EstLibre && salle.CoursEnCours != null)
                            {
                                <p class="text-muted small mb-0">
                                    <i class="bi bi-exclamation-circle me-1"></i>
                                    En cours : @salle.CoursEnCours.Matiere?.NomMatiere (@salle.CoursEnCours.Classe?.NomClasse)
                                </p>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">
                                    <i class="bi bi-info-circle me-1"></i> Aucun cours en ce moment.
                                </p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
