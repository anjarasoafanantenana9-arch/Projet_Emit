@model IEnumerable<EMIT.Models.Cours>

@{
    ViewData["Title"] = "Mes Cours - Espace Enseignant";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/prof.css" rel="stylesheet">
</head>
<body>

    @await Html.PartialAsync("_ProfSidebar", "Cours")

    <div class="main-content">

        @await Html.PartialAsync("_ProfHeader", ("Mes Cours", "Espace Enseignant > Mes Matières"))

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="fw-bold text-dark mb-0">Matières Assignées</h5>
                <p class="text-muted small mb-0">Liste complète de vos créneaux pour l'année en cours.</p>
            </div>
            <div class="badge bg-primary px-3 py-2 rounded-pill fs-6">
                Total : @Model.Count() Cours
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @if (!Model.Any())
            {
                <div class="col-12">
                    <div class="custom-card text-center text-muted">
                        Aucun cours ne vous est encore assigné.
                    </div>
                </div>
            }

            @foreach (var cours in Model)
            {
                <div class="col">
                    <div class="card h-100 custom-card border-start border-primary border-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-light text-primary fw-bold px-2 py-1 rounded">@cours.Jour</span>
                                <span class="text-muted small">
                                    <i class="bi bi-clock me-1"></i>
                                    @cours.HeureDebut.ToString(@"hh\:mm") - @cours.HeureFin.ToString(@"hh\:mm")
                                </span>
                            </div>
                            <h5 class="card-title fw-bold text-dark mb-2">@cours.Matiere?.NomMatiere</h5>
                            <p class="card-text text-muted small mb-1">
                                <i class="bi bi-people-fill me-2"></i><strong>Classe :</strong> @cours.Classe?.NomClasse
                            </p>
                            <p class="card-text text-muted small mb-0">
                                <i class="bi bi-door-open me-2"></i><strong>Salle :</strong> @cours.Salle?.NomSalle
                            </p>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-end pb-3">
                            <a asp-controller="Cours" asp-action="Details" asp-route-id="@cours.IdCours" class="btn btn-primary btn-sm rounded-3">Détails</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
