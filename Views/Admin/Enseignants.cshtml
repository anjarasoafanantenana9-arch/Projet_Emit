@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gestion des Enseignants";
}


<link rel="stylesheet" href="~/css/admin-enseignants.css" asp-append-version="true" />


<div class="content-body">


<div class="row g-3">


    <!-- Formulaire -->

    <div class="col-lg-4">


        <div class="card-custom">


            <div class="card-title-custom">
                Ajouter un enseignant
            </div>



            <form id="formEnseignant">


                <input type="hidden" id="idUtilisateur">


                <div class="mb-3">

                    <label class="form-label">
                        Nom
                    </label>

                    <input 
                        type="text"
                        id="nom"
                        class="form-control"
                        required>

                </div>



                <div class="mb-3">

                    <label class="form-label">
                        Prénom
                    </label>

                    <input 
                        type="text"
                        id="prenom"
                        class="form-control"
                        required>

                </div>








        




                <div class="mb-3">

                    <label class="form-label">
                        Plafond heures/jour
                    </label>


                    <input 
                        type="number"
                        id="plafond"
                        value="6"
                        min="1"
                        max="12"
                        class="form-control">

                </div>




                <button class="btn btn-primary w-100">

                    Enregistrer

                </button>


            </form>


        </div>


    </div>





    <!-- Tableau -->


    <div class="col-lg-8">


        <div class="card-custom">


            <div class="d-flex justify-content-between mb-3">


                <div class="card-title-custom">
                    Liste des enseignants
                </div>



                <button 
                    class="btn btn-outline-primary btn-sm"
                    onclick="chargerEnseignants()">

                    Actualiser

                </button>


            </div>




            <table class="table table-bordered">


                <thead>

                    <tr>

                        <th>ID</th>

                        <th>Nom</th>

                        <th>Prénom</th>

                        <th>Actions</th>

                    </tr>

                </thead>



                <tbody id="tableEnseignants">

                </tbody>


            </table>



        </div>



    </div>



</div>


</div>



@section Scripts{

<script src="~/js/admin-enseignants.js"></script>

}