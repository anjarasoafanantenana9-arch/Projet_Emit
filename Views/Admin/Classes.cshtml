@{
     Layout = "_AdminLayout";
    ViewData["Title"] = "Gestion des Classes";
}


@section Styles {
    <link rel="stylesheet" href="~/css/admin-classes.css" asp-append-version="true" />
}



<div class="row g-3">


    <!-- FORMULAIRE -->

    <div class="col-lg-4">


        <div class="card-custom">


            <div class="card-title-custom" id="titreFormulaireClasse">
                Ajouter une classe
            </div>



            <form id="formClasse">


                <input type="hidden" id="idClasse">



                <div class="mb-3">

                    <label class="form-label">
                        Nom Classe
                    </label>

                    <input 
                        type="text"
                        id="nomClasse"
                        class="form-control"
                        required>

                </div>




                <div class="mb-3">

                    <label class="form-label">
                        Niveau
                    </label>


                    <select 
                        id="idNiveau"
                        class="form-select"
                        required>

                        <option value="">
                            -- Choisir un niveau --
                        </option>

                    </select>

                </div>





                <div class="mb-3">

                    <label class="form-label">
                        Parcours
                    </label>


                    <select 
                        id="parcours"
                        class="form-select"
                        required>


                        <option value="">
                            -- Choisir un parcours --
                        </option>


                        <option value="INFORMATIQUE">
                            Informatique
                        </option>


                        <option value="AES">
                            AES
                        </option>


                        <option value="RPM">
                            RPM
                        </option>


                    </select>


                </div>






                <div class="mb-3">

                    <label class="form-label">
                        Effectif
                    </label>


                    <input 
                        type="number"
                        id="effectif"
                        class="form-control"
                        min="1"
                        required>


                </div>






                <div class="d-grid gap-2">


                    <button 
                        type="submit"
                        id="btnSubmitClasse"
                        class="btn btn-primary">


                        Enregistrer


                    </button>



                    <button 
                        type="button"
                        id="btnAnnulerEditionClasse"
                        class="btn btn-outline-secondary d-none">


                        Annuler la modification


                    </button>


                </div>



            </form>



        </div>



    </div>









    <!-- TABLEAU -->

    <div class="col-lg-8">


        <div class="card-custom">



            <div class="d-flex justify-content-between mb-3">


                <div class="card-title-custom">

                    Liste des classes

                </div>




                <button 
                    class="btn btn-outline-primary btn-sm"
                    onclick="chargerClasses()">


                    <i class="bi bi-arrow-clockwise"></i>
                    Actualiser


                </button>



            </div>







            <div class="table-responsive">


                <table class="table table-bordered">


                    <thead>


                        <tr>

                            <th>ID</th>

                            <th>Classe</th>

                            <th>Niveau</th>

                            <th>Parcours</th>

                            <th>Effectif</th>

                            <th>Actions</th>


                        </tr>


                    </thead>




                    <tbody id="tableClasses">


                    </tbody>




                </table>


            </div>



        </div>


    </div>



</div>





@section Scripts {

    <script src="~/js/admin-classes.js" asp-append-version="true"></script>

}