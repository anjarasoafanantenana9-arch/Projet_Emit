<!DOCTYPE html>
<html lang="fr">
<head>

    <meta charset="utf-8" />

    <title>@ViewData["Title"] - EMIT Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/admin-cours.css" />

    <!-- AJOUT : permet aux vues d'injecter leur propre CSS via @@section Styles -->
    @RenderSection("Styles", required: false)

</head>


<body>


    <!-- Sidebar -->

    <div class="sidebar">

        <div class="sidebar-brand">

            <div class="logo-wrapper">
                <img src="~/images/emit-logo.png" alt="Logo EMIT">
            </div>

        </div>


        <ul class="sidebar-menu">

            <li>
                <a href="/Admin/Index" class="sidebar-link">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>
            </li>


            <div class="menu-label">
                Planification
            </div>


            <li>
                <a href="/Admin/EmploiTemps" class="sidebar-link">
                    <i class="bi bi-calendar3"></i>
                    Emploi du Temps
                </a>
            </li>


            <li>
                <a href="/Admin/Salles" class="sidebar-link">
                    <i class="bi bi-door-open"></i>
                    Salles
                </a>
            </li>


            <li>
                <a href="/Admin/Enseignants" class="sidebar-link">
                    <i class="bi bi-person-video3"></i>
                    Enseignants
                </a>
            </li>


            <li>
                <a href="/Admin/Classes" class="sidebar-link">
                    <i class="bi bi-mortarboard"></i>
                    Classes
                </a>
            </li>


            <li>
                <a href="/Admin/Matieres" class="sidebar-link">
                    <i class="bi bi-book"></i>
                    Matières
                </a>
            </li>

        </ul>

        <form asp-controller="Account" asp-action="Logout" method="post" style="padding: 0 12px; margin-top: auto;">
            <button type="submit" class="sidebar-link border-0 bg-transparent w-100 text-start" style="cursor: pointer;">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </button>
        </form>

    </div>
     


    <!-- Contenu -->

    <div class="main-content">


        <!-- Topbar -->

        <div class="topbar">

            <div class="topbar-title">

                <h2>
                    @ViewData["Title"]
                </h2>

            </div>


            <div class="topbar-right">

                <div class="user-profile">

                    <span class="text-muted">
                        Secrétariat EMIT
                    </span>

                    <div class="user-avatar">
                        S
                    </div>

                </div>

            </div>


        </div>



        @RenderBody()


    </div>




<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


@RenderSection("Scripts", required:false)


</body>

</html>