@model EMIT.Models.Enseignant

@{
    ViewData["Title"] = "Mon Profil - Espace Enseignant";
    var initiale = (Model.Prenom ?? "P").Trim().FirstOrDefault().ToString().ToUpper();
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/prof.css" rel="stylesheet">
</head>
<body>

    @await Html.PartialAsync("_ProfSidebar", "Profil")

    <div class="main-content">

        @await Html.PartialAsync("_ProfHeader", ("Mon Profil", "Paramètres > Informations du compte"))

        @if (TempData["Succes"] != null)
        {
            <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Succes"]</div>
        }

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="custom-card text-center">
                    <div class="profile-avatar-large bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold mx-auto mb-3">
                        @initiale
                    </div>
                    <h5 class="fw-bold text-dark mb-1">@Model.Prenom @Model.Nom</h5>
                    <p class="text-muted small mb-3">Enseignant à l'EMIT</p>
                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill small fw-bold">
                        Plafond : @Model.PlafondHeuresJournalieres h / jour
                    </span>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="custom-card mb-4">
                    <h5 class="fw-bold text-dark mb-4"><i class="bi bi-person me-2 text-primary"></i>Détails du compte</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Nom Complet</label>
                            <input type="text" class="form-control bg-light" value="@Model.Prenom @Model.Nom" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Adresse Email</label>
                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Rôle</label>
                            <input type="text" class="form-control bg-light" value="@Model.Role" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Plafond d'heures / jour</label>
                            <input type="text" class="form-control bg-light" value="@Model.PlafondHeuresJournalieres h" readonly>
                        </div>
                    </div>
                    <p class="text-muted small mt-3 mb-0">
                        Pour modifier vos informations personnelles, contactez un administrateur.
                    </p>
                </div>

                <div class="custom-card">
                    <h5 class="fw-bold text-dark mb-4"><i class="bi bi-shield-lock me-2 text-danger"></i>Sécurité du compte</h5>

                    <form asp-controller="Prof" asp-action="ModifierMotDePasse" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-secondary small fw-bold">Mot de passe actuel</label>
                                <input type="password" class="form-control" name="MotDePasseActuel" placeholder="••••••••" required>
                                <span class="text-danger small">@Html.ValidationMessage("MotDePasseActuel")</span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-secondary small fw-bold">Nouveau mot de passe</label>
                                <input type="password" class="form-control" name="NouveauMotDePasse" placeholder="••••••••" required>
                                <span class="text-danger small">@Html.ValidationMessage("NouveauMotDePasse")</span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-secondary small fw-bold">Confirmer le mot de passe</label>
                                <input type="password" class="form-control" name="ConfirmationMotDePasse" placeholder="••••••••" required>
                                <span class="text-danger small">@Html.ValidationMessage("ConfirmationMotDePasse")</span>
                            </div>
                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-primary rounded-3 btn-sm px-4">
                                    Mettre à jour le mot de passe
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
