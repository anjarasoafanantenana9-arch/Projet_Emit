@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gestion des Enseignants";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-enseignants.css" asp-append-version="true" />
}

<div class="row g-3">

    <!-- Formulaire -->
    <div class="col-lg-4">

        <div class="card-custom">

            <div class="card-title-custom" id="titreFormulaireEnseignant">
                Ajouter un enseignant
            </div>

            <form id="formEnseignant">

                <input type="hidden" id="idUtilisateur">

                <div class="mb-3">
                    <label class="form-label">Nom</label>
                    <input type="text" id="nom" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Prénom</label>
                    <input type="text" id="prenom" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" id="email" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" id="labelMotDePasse">Mot de passe</label>
                    <input type="password" id="motDePasse" class="form-control" placeholder="Requis à la création">
                    <small class="text-muted d-none" id="hintMotDePasse" style="font-size:0.7rem;">
                        Laissez vide pour ne pas changer le mot de passe.
                    </small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Matières enseignées</label>
                    <select id="idMatieres" class="form-select" multiple size="5" required></select>
                    <small class="text-muted" style="font-size:0.7rem;">
                        Maintenez Ctrl (ou Cmd sur Mac) pour sélectionner plusieurs matières.
                    </small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Plafond heures/jour</label>
                    <input type="number" id="plafond" value="6" min="1" max="12" class="form-control">
                </div>

                <button type="submit" class="btn btn-primary w-100" id="btnSubmitEnseignant">
                    Enregistrer
                </button>

                <button type="button" class="btn btn-outline-secondary w-100 mt-2 d-none" id="btnAnnulerEditionEnseignant">
                    Annuler la modification
                </button>

            </form>

        </div>

    </div>

    <!-- Tableau -->
    <div class="col-lg-8">

        <div class="card-custom">

            <div class="d-flex justify-content-between mb-3">
                <div class="card-title-custom">
                    Liste des enseignants
                </div>

                <button class="btn btn-outline-primary btn-sm" onclick="chargerEnseignants()">
                    <i class="bi bi-arrow-clockwise"></i> Actualiser
                </button>
            </div>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Matières</th>
                        <th>Plafond h/j</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableEnseignants"></tbody>
            </table>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/admin-enseignants.js"></script>
}
