<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMIT Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --sidebar-width: 260px;
            --navy-dark: #0f172a;
            --bg-main: #f8fafc;
            --emit-blue: #3b82f6;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Conteneur principal en Flexbox pour mettre la sidebar à gauche et le contenu à droite */
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR FIXE À GAUCHE */
        .sidebar {
            width: var(--sidebar-width);
            background-color: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            padding: 20px 14px;
        }

        .sidebar-brand {
            text-align: center;
            margin-bottom: 25px;
            padding: 10px;
            background: #f8fafc;
            border-radius: 12px;
        }

        .logo-wrapper img {
            max-width: 100%;
            max-height: 50px;
            object-fit: contain;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .menu-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            font-weight: 700;
            padding: 12px 10px 6px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            color: #475569;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.88rem;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .sidebar-link:hover {
            background-color: #f1f5f9;
            color: var(--emit-blue);
        }

        /* Zone de déconnexion tout en bas */
        .logout-container {
            margin-top: auto;
            padding-top: 15px;
        }

        .btn-logout {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            background: #fef2f2;
            color: #ef4444;
            border: 1px solid #fee2e2;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.88rem;
            cursor: pointer;
            transition: background 0.2s;
        }
        .btn-logout:hover {
            background: #fee2e2;
        }

        /* CONTENU À DROITE (DÉCALÉ DE LA LARGEUR DE LA SIDEBAR) */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* TOPBAR MODERNE */
        .topbar {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
            min-height: 65px;
        }

        .topbar-title h2 {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--navy-dark);
            margin: 0;
        }

        .topbar-right {
            display: flex;
            align-items: center;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-profile span {
            font-size: 0.85rem;
            font-weight: 600;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            background-color: #e0f2fe;
            color: #0284c7;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
        }

        /* Zone dynamique en bas de la topbar */
        .content-body {
            padding: 30px;
            flex: 1;
        }

     @@media (max-width: 992px) {
    .sidebar { width: 70px; padding: 15px 5px; }
    .sidebar span, .menu-label, .btn-logout span { display: none; }
    .main-content { margin-left: 70px; }
    .topbar { padding: 15px; }
}
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="admin-wrapper">

        <nav class="sidebar">
            <div class="sidebar-brand">
                <div class="logo-wrapper">
                    <img src="~/images/emit-logo.png" alt="Logo EMIT">
                </div>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="/Admin/Index" class="sidebar-link">
                        <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                    </a>
                </li>

                <div class="menu-label">Planification</div>

                <li>
                    <a href="/Admin/EmploiTemps" class="sidebar-link">
                        <i class="bi bi-calendar3"></i> <span>Emploi du Temps</span>
                    </a>
                </li>

                <li>
                    <a href="/Admin/Salles" class="sidebar-link">
                        <i class="bi bi-door-open"></i> <span>Salles</span>
                    </a>
                </li>

                <li>
                    <a href="/Admin/Enseignants" class="sidebar-link">
                        <i class="bi bi-person-video3"></i> <span>Enseignants</span>
                    </a>
                </li>

                <li>
                    <a href="/Admin/Classes" class="sidebar-link">
                        <i class="bi bi-mortarboard"></i> <span>Classes</span>
                    </a>
                </li>

                <li>
                    <a href="/Admin/Matieres" class="sidebar-link">
                        <i class="bi bi-book"></i> <span>Matières</span>
                    </a>
                </li>
            </ul>

            <div class="logout-container">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i> <span>Déconnexion</span>
                    </button>
                </form>
            </div>
        </nav>

        <div class="main-content">
            
            <header class="topbar">
                <div class="topbar-title">
                    <h2>@ViewData["Title"]</h2>
                </div>

                <div class="topbar-right">
                    <div class="user-profile">
                        <span class="text-muted">Secrétariat EMIT</span>
                        <div class="user-avatar">S</div>
                    </div>
                </div>
            </header>

            <main class="content-body">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6Rzsn9g66QVNV1rlb3uoO3661739BpQ68v87BH95OGNyZPhcTNXj1NW7RuBCsyN" crossorigin="anonymous"></script>
</body>
</html>