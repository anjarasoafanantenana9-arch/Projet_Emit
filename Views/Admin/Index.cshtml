@model EMIT.Models.Utilisateur

@{
    ViewData["Title"] = "Espace Administrateur";
}

<h1>Espace Administrateur</h1>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Prenom @Model.Nom</h5>
        <p class="card-text">
            <strong>ID utilisateur :</strong> @Model.IdUtilisateur<br />
            <strong>Email :</strong> @Model.Email<br />
            <strong>Rôle :</strong> @Model.Role
        </p>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Cours" asp-action="Index" class="btn btn-primary">Gérer l'emploi du temps</a>
    <a asp-controller="Utilisateurs" asp-action="Index" class="btn btn-secondary">Gérer les comptes</a>
    <a asp-controller="Salles" asp-action="Index" class="btn btn-secondary">Gérer les salles</a>
    <a asp-controller="Niveaux" asp-action="Index" class="btn btn-secondary">Gérer les niveaux</a>
</div>
