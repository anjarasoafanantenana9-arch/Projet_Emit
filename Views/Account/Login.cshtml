@model EMIT.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Connexion";
}

<h1>Connexion</h1>

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success">@TempData["Succes"]</div>
}

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" style="max-width: 400px;">
    <div class="form-group mb-3">
        <label asp-for="Email" class="control-label"></label>
        <input asp-for="Email" class="form-control" autofocus />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MotDePasse" class="control-label"></label>
        <input asp-for="MotDePasse" class="form-control" />
        <span asp-validation-for="MotDePasse" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="SeSouvenirDeMoi" class="form-check-input" />
        <label asp-for="SeSouvenirDeMoi" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Se connecter</button>
</form>

<div class="mt-3">
    <a asp-controller="Account" asp-action="Register" class="btn btn-link">Créer un compte</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
