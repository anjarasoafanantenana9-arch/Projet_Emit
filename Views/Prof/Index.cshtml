@model EMIT.Models.Enseignant

@{
    ViewData["Title"] = "Espace Enseignant - Tableau de bord";

    var niveaux = (List<EMIT.Models.Niveau>)ViewData["Niveaux"]!;

    var jours = new[]
    {
        EMIT.Models.JourSemaine.Lundi,
        EMIT.Models.JourSemaine.Mardi,
        EMIT.Models.JourSemaine.Mercredi,
        EMIT.Models.JourSemaine.Jeudi,
        EMIT.Models.JourSemaine.Vendredi,
    };

    var joursLabels = new[] { "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi" };

    // Un cours est "Matin" s'il commence avant midi, "Après-midi" sinon
    bool EstMatin(TimeSpan heureDebut) => heureDebut < new TimeSpan(12, 0, 0);
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/prof.css" rel="stylesheet">
    <link href="~/css/admin-cours.css" rel="stylesheet">
</head>
<body>

    @await Html.PartialAsync("_ProfSidebar", "Index")

    <div class="main-content">

        @await Html.PartialAsync("_ProfHeader", ("Mon Emploi du Temps", "Espace Enseignant > Planification"))

        @if (!niveaux.Any())
        {
            <div class="custom-card">
                <p class="text-muted mb-0">Aucun niveau trouvé.</p>
            </div>
        }

        @foreach (var niveau in niveaux)
        {
            // On ne garde que les cours de CET enseignant (Model.Cours est déjà filtré côté controller)
            // qui appartiennent à ce niveau précis
            var coursDuNiveau = Model.Cours
                .Where(c => c.Classe != null && c.Classe.IdNiveau == niveau.IdNiveau)
                .ToList();

            <div class="custom-card mb-3">
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="fw-bold m-0">@niveau.NomNiveau</h5>
                    <a asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrow-clockwise"></i> Actualiser
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-timetable m-0">
                        <thead>
                            <tr>
                                <th></th>
                                @foreach (var label in joursLabels)
                                {
                                    <th>@label</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="periode-label">Matin</td>
                                @foreach (var jour in jours)
                                {
                                    var coursCellule = coursDuNiveau
                                        .Where(c => c.Jour == jour && EstMatin(c.HeureDebut))
                                        .ToList();

                                    <td>
                                        @foreach (var c in coursCellule)
                                        {
                                            <div class="course-slot">
                                                <div class="course-time">
                                                    <i class="bi bi-clock"></i>
                                                    @c.HeureDebut.ToString(@"hh\:mm") - @c.HeureFin.ToString(@"hh\:mm")
                                                </div>
                                                <strong>@c.Matiere?.NomMatiere</strong><br>
                                                Classe : @c.Classe?.NomClasse<br>
                                                <span class="badge-salle">Salle @c.Salle?.NomSalle</span>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                            <tr>
                                <td class="periode-label">Après-midi</td>
                                @foreach (var jour in jours)
                                {
                                    var estMercrediApresMidi = jour == EMIT.Models.JourSemaine.Mercredi;
                                    var coursCellule = coursDuNiveau
                                        .Where(c => c.Jour == jour && !EstMatin(c.HeureDebut))
                                        .ToList();

                                    if (estMercrediApresMidi && !coursCellule.Any())
                                    {
                                        <td class="cell-bloquee">
                                            <span class="cell-bloquee-texte">Bloqué<br>(sauf dérogation)</span>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            @foreach (var c in coursCellule)
                                            {
                                                <div class="course-slot">
                                                    <div class="course-time">
                                                        <i class="bi bi-clock"></i>
                                                        @c.HeureDebut.ToString(@"hh\:mm") - @c.HeureFin.ToString(@"hh\:mm")
                                                    </div>
                                                    <strong>@c.Matiere?.NomMatiere</strong><br>
                                                    Classe : @c.Classe?.NomClasse<br>
                                                    <span class="badge-salle">Salle @c.Salle?.NomSalle</span>
                                                </div>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
